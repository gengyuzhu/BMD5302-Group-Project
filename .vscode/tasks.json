{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Frontend",
      "type": "npm",
      "script": "dev",
      "path": ".",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*vite.*",
          "endsPattern": ".*Local:.*127.0.0.1:5173.*"
        }
      }
    }
  ]
}
